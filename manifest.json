{
  "manifest_version": 3,
  "name": "AIP/AIC PDF Summarizer",
  "version": "1.0",
  "description": "Reads and summarizes AIP SUP and AIC PDF documents using Gemini AI.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  }
}
